<% layout("/layout/boilerplate") %>
<body>
 
   <div class="row row-cols-xxl-3 row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4">
    <% for(let Listing of allListing){ %>
      <%= console.log(Listing) %>
    <a href="/Listing/<%=Listing._id %>" class="listing-link">
      <div class="card col">
      <img
  src="<%= typeof Listing.image === 'string' ? Listing.image : Listing.image.url %>"
  class="card-img-top"
  alt="listing_image"
  style="height: 20rem"
    />
        <div class="card-img-overlay"></div>
        <div class="card-body">
          <p class="card-text">
            <%=Listing.title%> <br />
            <%= new Intl.NumberFormat("en-IN", { style: "currency", currency: "INR" }).format(Listing.price) %>
          </p>
        </div>
      </div>
    </a>
    <% } %>
  </div>
  <br />
 <button style="width:100%;padding:12px;background:#ff385c;color:#fff;border:none;border-radius:10px;font-size:16px;font-weight:500;cursor:pointer;transition:.3s;" onmouseover="this.style.background='#e11d48'" onmouseout="this.style.background='#ff385c'"><a href="/listing/new"><h2 >Creat an new list</h2></a></button>
</body>
